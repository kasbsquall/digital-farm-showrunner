# Copy to backend/.env and fill in. NEVER commit the real .env.

# Database — SQLite for local dev; Alibaba Cloud RDS (PostgreSQL) in prod.
DATABASE_URL=sqlite:///./farm.db

# Qwen Cloud (DashScope) — OpenAI-compatible endpoint.
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_TEXT_MODEL=qwen-plus

# Video generation model (Wan / HappyHorse via DashScope).
VIDEO_MODEL=wan2.1-t2v-turbo

# Alibaba Cloud OSS — video storage + deploy proof.
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com

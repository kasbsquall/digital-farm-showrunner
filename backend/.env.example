# Copy to backend/.env and fill in. NEVER commit the real .env.

# Database — SQLite for local dev; Alibaba Cloud RDS (PostgreSQL) in prod.
DATABASE_URL=sqlite:///./farm.db

# Qwen Cloud — OpenAI-compatible. El endpoint se auto-selecciona según el prefijo:
#   key "sk-sp-..." (créditos hackathon / Token Plan) → token-plan.ap-southeast-1
#   key "sk-..."    (pay-as-you-go)                   → dashscope-intl
# Basta con pegar la key; no toques las URLs.
QWEN_API_KEY=
QWEN_TEXT_MODEL=qwen3.7-plus

# Video = HappyHorse (texto→video). Imagen/thumbnail = Wan2.6 (texto→imagen).
VIDEO_MODEL=happyhorse-1.1-t2v
IMAGE_MODEL=wan2.6-t2i

# ElevenLabs — voiceover for the demo video (optional).
ELEVENLABS_API_KEY=

# Alibaba Cloud OSS — video storage + deploy proof.
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com
